# ── URL ───────────────────────────────────────────────────────────────────
# Local dev
TEST_BASE_URL=http://localhost:3000

# CI/Docker — uncomment khi dùng
# TEST_BASE_URL=http://frontend:3000

# ── Test credentials ──────────────────────────────────────────────────────
# Tài khoản test phải tồn tại sẵn trong DB (seed data)
TEST_PATIENT_EMAIL=newpatient@example.com
TEST_PATIENT_PASSWORD=securePass123

TEST_DOCTOR_EMAIL=doctor@test.com
TEST_DOCTOR_PASSWORD=password123    

TEST_ADMIN_EMAIL=admin@admin.com
TEST_ADMIN_PASSWORD=password123

# ── Options ───────────────────────────────────────────────────────────────
# Bật Allure report khi cần
# ALLURE_REPORT=true
