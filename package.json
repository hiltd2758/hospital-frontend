{
  "name": "hospital-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
"scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "test": "npx codeceptjs run --config codecept.conf.cjs",
    "test:headless": "CI=true npx codeceptjs run --config codecept.conf.cjs",
    "test:patient": "npx codeceptjs run --config codecept.conf.cjs --grep 'Patient'",
    "test:doctor": "npx codeceptjs run --config codecept.conf.cjs --grep 'Doctor'",
    "test:admin": "npx codeceptjs run --config codecept.conf.cjs --grep 'Admin'",
    "test:report": "ALLURE_REPORT=true npx codeceptjs run --config codecept.conf.cjs"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.0",
    "@tanstack/react-query": "^5.51.1",
    "@tanstack/react-query-devtools": "^5.51.1",
    "axios": "^1.7.3",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "lucide-react": "^0.414.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.52.1",
    "react-router-dom": "^6.26.0",
    "tailwind-merge": "^2.4.0",
    "zod": "^3.23.8",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@codeceptjs/configure": "^0.10.0",
    "@types/node": "^25.9.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.15.0",
    "@typescript-eslint/parser": "^7.15.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "codeceptjs": "^3.6.0",
    "dotenv": "^17.4.2",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.7",
    "playwright": "^1.40.0",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.6",
    "typescript": "^5.5.3",
    "vite": "^5.3.4"
  }
}
